version: '3'

vars:
  PROJECT_NAME: {{ project_name }}
  OPENAPI_SPEC: ./shared/api-contracts/openapi.yml
  OPENAPI_GENERATOR: openapi-generator-cli

includes:
{% if "backend" in platforms %}
  backend:
    taskfile: ./backend/Taskfile.yml
    dir: ./backend
{% endif %}
{% if "web-user-app" in platforms %}
  web-user-app:
    taskfile: ./web-user-app/Taskfile.yml
    dir: ./web-user-app
{% endif %}
{% if "web-admin-portal" in platforms %}
  web-admin-portal:
    taskfile: ./web-admin-portal/Taskfile.yml
    dir: ./web-admin-portal
{% endif %}
{% if "mobile-android" in platforms %}
  mobile-android:
    taskfile: ./mobile-android/Taskfile.yml
    dir: ./mobile-android
{% endif %}
{% if "mobile-ios" in platforms %}
  mobile-ios:
    taskfile: ./mobile-ios/Taskfile.yml
    dir: ./mobile-ios
{% endif %}

tasks:
  # ===========================================================================
  # API Client Generation
  # ===========================================================================
  generate-clients:
    desc: "Generate typed API clients from OpenAPI spec for all platforms"
    cmds:
      - cmd: "{{'{{'}} .OPENAPI_GENERATOR {{'}}'}} validate -i {{'{{'}} .OPENAPI_SPEC {{'}}'}}"
{% if "backend" in platforms %}
      - task: generate-client-backend
{% endif %}
{% if "web-user-app" in platforms or "web-admin-portal" in platforms %}
      - task: generate-client-typescript
{% endif %}
{% if "mobile-android" in platforms %}
      - task: generate-client-mobile-android
{% endif %}
{% if "mobile-ios" in platforms %}
      - task: generate-client-mobile-ios
{% endif %}
    sources:
      - "{{'{{'}} .OPENAPI_SPEC {{'}}'}}"

{% if "backend" in platforms %}
  generate-client-backend:
    desc: "Generate Spring Boot server interfaces from OpenAPI"
    internal: true
    cmds:
      - >
        {{'{{'}} .OPENAPI_GENERATOR {{'}}'}} generate
        -i {{'{{'}} .OPENAPI_SPEC {{'}}'}}
        -g kotlin-spring
        -o ./backend/src/generated
        --additional-properties=interfaceOnly=true,useSpringBoot3=true,useTags=true
        --package-name="{{ package_identifier }}.api"
{% endif %}

{% if "web-user-app" in platforms or "web-admin-portal" in platforms %}
  generate-client-typescript:
    desc: "Generate TypeScript Axios client from OpenAPI"
    internal: true
    cmds:
      - >
        {{'{{'}} .OPENAPI_GENERATOR {{'}}'}} generate
        -i {{'{{'}} .OPENAPI_SPEC {{'}}'}}
        -g typescript-axios
        -o ./shared/generated/typescript-client
        --additional-properties=supportsES6=true,withSeparateModelsAndApi=true
{% endif %}

{% if "mobile-android" in platforms %}
  generate-client-mobile-android:
    desc: "Generate Kotlin Retrofit client from OpenAPI"
    internal: true
    cmds:
      - >
        {{'{{'}} .OPENAPI_GENERATOR {{'}}'}} generate
        -i {{'{{'}} .OPENAPI_SPEC {{'}}'}}
        -g kotlin
        -o ./mobile-android/app/src/main/java/generated
        --additional-properties=library=jvm-retrofit2,serializationLibrary=kotlinx_serialization
        --package-name="{{ package_identifier }}.api"
{% endif %}

{% if "mobile-ios" in platforms %}
  generate-client-mobile-ios:
    desc: "Generate Swift URLSession client from OpenAPI"
    internal: true
    cmds:
      - >
        {{'{{'}} .OPENAPI_GENERATOR {{'}}'}} generate
        -i {{'{{'}} .OPENAPI_SPEC {{'}}'}}
        -g swift6
        -o ./mobile-ios/Generated/APIClient
        --additional-properties=library=urlsession,projectName={{ ios_module_name }}API
{% endif %}

  # ===========================================================================
  # Cross-Platform Commands
  # ===========================================================================
  lint:
    desc: "Lint all platforms"
    cmds:
{% if "backend" in platforms %}
      - task: backend:lint
{% endif %}
{% if "web-user-app" in platforms %}
      - task: web-user-app:lint
{% endif %}
{% if "web-admin-portal" in platforms %}
      - task: web-admin-portal:lint
{% endif %}
{% if "mobile-android" in platforms %}
      - task: mobile-android:lint
{% endif %}

  test:
    desc: "Run tests for all platforms"
    cmds:
{% if "backend" in platforms %}
      - task: backend:test
{% endif %}
{% if "web-user-app" in platforms %}
      - task: web-user-app:test
{% endif %}
{% if "web-admin-portal" in platforms %}
      - task: web-admin-portal:test
{% endif %}
{% if "mobile-android" in platforms %}
      - task: mobile-android:test
{% endif %}

  # ===========================================================================
  # Utilities
  # ===========================================================================
  validate-api:
    desc: "Validate OpenAPI spec"
    cmds:
      - "{{'{{'}} .OPENAPI_GENERATOR {{'}}'}} validate -i {{'{{'}} .OPENAPI_SPEC {{'}}'}}"

{% if "backend" in platforms %}
  # ===========================================================================
  # Infrastructure (Azure)
  # ===========================================================================
  infra:setup:
    desc: "Run all Azure infrastructure setup scripts (first-time only)"
    dir: ./infra/azure
    cmds:
      - bash 00-setup-resource-group.sh {{'{{'}} .CLI_ARGS {{'}}'}}
      - bash 01-setup-foundation.sh {{'{{'}} .CLI_ARGS {{'}}'}}
      - bash 02-setup-database.sh {{'{{'}} .CLI_ARGS {{'}}'}}
      - bash 03-setup-container-apps-env.sh {{'{{'}} .CLI_ARGS {{'}}'}}
      - bash 04-setup-storage.sh {{'{{'}} .CLI_ARGS {{'}}'}}
      - bash 05-build-and-push-images.sh {{'{{'}} .CLI_ARGS {{'}}'}}
      - bash 06-deploy-backend.sh {{'{{'}} .CLI_ARGS {{'}}'}}
      - bash 07-show-deployment-info.sh {{'{{'}} .CLI_ARGS {{'}}'}}

  infra:update-backend:
    desc: "Rebuild and redeploy backend (zero-downtime)"
    dir: ./infra/azure
    cmds:
      - bash update-backend.sh {{'{{'}} .CLI_ARGS {{'}}'}}

  infra:info:
    desc: "Show deployment information"
    dir: ./infra/azure
    cmds:
      - bash 07-show-deployment-info.sh {{'{{'}} .CLI_ARGS {{'}}'}}

  infra:check-secrets:
    desc: "Validate all required secrets are configured"
    dir: ./infra/azure
    cmds:
      - bash check-secrets.sh
{% endif %}
