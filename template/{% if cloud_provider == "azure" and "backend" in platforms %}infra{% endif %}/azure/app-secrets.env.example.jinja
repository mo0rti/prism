# =============================================================================
# {{ project_name }} — Application Secrets
# =============================================================================
# Copy this file to app-secrets.env and fill in your values.
# NEVER commit app-secrets.env to version control.

# JWT
JWT_SECRET=generate-a-strong-secret-here
JWT_EXPIRATION_MS=86400000

{% if "google" in auth_methods %}
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
{% endif %}
{% if "apple" in auth_methods %}
# Apple Sign-In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=    # base64 encoded .p8 key
{% endif %}
{% if "facebook" in auth_methods %}
# Facebook Login
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
{% endif %}
{% if "microsoft" in auth_methods %}
# Microsoft Account
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
{% endif %}

# Add any additional API keys below:
# SOME_API_KEY=
