services:
{% if "backend" in platforms %}
  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    ports:
      - "8080:8080"
    environment:
      SPRING_PROFILES_ACTIVE: dev
      SPRING_DATASOURCE_URL: jdbc:postgresql://db:5432/{{ project_slug | replace('-', '_') }}
      SPRING_DATASOURCE_USERNAME: {{ project_slug | replace('-', '_') }}
      SPRING_DATASOURCE_PASSWORD: localdev
      SPRING_DATA_REDIS_HOST: redis
      SPRING_DATA_REDIS_PORT: "6379"
      JWT_SECRET: dev-jwt-secret-do-not-use-in-production
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy

  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: {{ project_slug | replace('-', '_') }}
      POSTGRES_USER: {{ project_slug | replace('-', '_') }}
      POSTGRES_PASSWORD: localdev
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ project_slug | replace('-', '_') }}"]
      interval: 5s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    volumes:
      - redisdata:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
{% endif %}

volumes:
{% if "backend" in platforms %}
  pgdata:
  redisdata:
{% endif %}
