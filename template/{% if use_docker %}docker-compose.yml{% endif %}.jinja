services:
{% if "backend" in platforms %}
  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    ports:
      - "8080:8080"
    environment:
      SPRING_PROFILES_ACTIVE: dev
{% if database == "postgres" %}
      SPRING_DATASOURCE_URL: jdbc:postgresql://db:5432/{{ project_slug | replace('-', '_') }}
      SPRING_DATASOURCE_USERNAME: {{ project_slug | replace('-', '_') }}
      SPRING_DATASOURCE_PASSWORD: localdev
{% elif database == "mysql" %}
      SPRING_DATASOURCE_URL: jdbc:mysql://db:3306/{{ project_slug | replace('-', '_') }}
      SPRING_DATASOURCE_USERNAME: {{ project_slug | replace('-', '_') }}
      SPRING_DATASOURCE_PASSWORD: localdev
{% endif %}
      JWT_SECRET: dev-jwt-secret-do-not-use-in-production
    depends_on:
      db:
        condition: service_healthy

{% if database == "postgres" %}
  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: {{ project_slug | replace('-', '_') }}
      POSTGRES_USER: {{ project_slug | replace('-', '_') }}
      POSTGRES_PASSWORD: localdev
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ project_slug | replace('-', '_') }}"]
      interval: 5s
      timeout: 5s
      retries: 5
{% elif database == "mysql" %}
  db:
    image: mysql:8.0
    environment:
      MYSQL_DATABASE: {{ project_slug | replace('-', '_') }}
      MYSQL_USER: {{ project_slug | replace('-', '_') }}
      MYSQL_PASSWORD: localdev
      MYSQL_ROOT_PASSWORD: localdev
    ports:
      - "3306:3306"
    volumes:
      - mysqldata:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 5s
      timeout: 5s
      retries: 5
{% endif %}
{% endif %}

{% if database == "postgres" %}
volumes:
  pgdata:
{% elif database == "mysql" %}
volumes:
  mysqldata:
{% endif %}
