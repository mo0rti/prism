---
to: "<%= entity ? 'backend/src/main/kotlin/{{ package_identifier | replace('.', '/') }}/features/' + h.changeCase.camel(name) + '/model/' + h.changeCase.pascal(entity) + '.kt' : null %>"
---
package {{ package_identifier }}.features.<%= h.changeCase.camel(name) %>.model

import jakarta.persistence.*
import java.time.Instant

@Entity
@Table(name = "<%= h.changeCase.snake(h.inflection.pluralize(entity)) %>")
class <%= h.changeCase.pascal(entity) %>(
    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    val id: Long = 0,

    // TODO: Add entity fields

    @Column(nullable = false, updatable = false)
    val createdAt: Instant = Instant.now(),

    @Column(nullable = false)
    var updatedAt: Instant = Instant.now(),
) {
    @PreUpdate
    fun onUpdate() {
        updatedAt = Instant.now()
    }
}
