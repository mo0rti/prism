name: {{ project_name }}
options:
  bundleIdPrefix: {{ package_identifier }}
  deploymentTarget:
    iOS: "17.0"
  xcodeVersion: "26.0"
  generateEmptyDirectories: true

settings:
  base:
    SWIFT_VERSION: "6.0"
    MARKETING_VERSION: "0.1.0"
    CURRENT_PROJECT_VERSION: 1

targets:
  {{ ios_module_name }}:
    type: application
    platform: iOS
    sources:
      - path: {{ project_slug }}
    configFiles:
      Debug: Config/Debug.xcconfig
      Release: Config/Release.xcconfig
    settings:
      base:
        INFOPLIST_FILE: {{ project_slug }}/Info.plist
        PRODUCT_BUNDLE_IDENTIFIER: {{ package_identifier }}
        ASSETCATALOG_COMPILER_APPICON_NAME: AppIcon
    scheme:
      testTargets:
        - {{ ios_module_name }}Tests
        - {{ ios_module_name }}UITests

  {{ ios_module_name }}Tests:
    type: bundle.unit-test
    platform: iOS
    sources:
      - path: {{ project_slug }}Tests
    settings:
      base:
        GENERATE_INFOPLIST_FILE: YES
    dependencies:
      - target: {{ ios_module_name }}

  {{ ios_module_name }}UITests:
    type: bundle.ui-testing
    platform: iOS
    sources:
      - path: {{ project_slug }}UITests
    settings:
      base:
        GENERATE_INFOPLIST_FILE: YES
        TEST_TARGET_NAME: {{ ios_module_name }}
    dependencies:
      - target: {{ ios_module_name }}
