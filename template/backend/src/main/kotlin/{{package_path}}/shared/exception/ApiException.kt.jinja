package {{ package_identifier }}.shared.exception

import org.springframework.http.HttpStatus

open class ApiException(
    val status: HttpStatus,
    val code: String,
    override val message: String,
    val details: Map<String, Any>? = null
) : RuntimeException(message)

class NotFoundException(
    message: String,
    code: String = "NOT_FOUND",
    details: Map<String, Any>? = null
) : ApiException(HttpStatus.NOT_FOUND, code, message, details)

class ConflictException(
    message: String,
    code: String = "CONFLICT",
    details: Map<String, Any>? = null
) : ApiException(HttpStatus.CONFLICT, code, message, details)

class UnauthorizedException(
    message: String = "Authentication required",
    code: String = "UNAUTHORIZED",
    details: Map<String, Any>? = null
) : ApiException(HttpStatus.UNAUTHORIZED, code, message, details)

class ForbiddenException(
    message: String = "Insufficient permissions",
    code: String = "FORBIDDEN",
    details: Map<String, Any>? = null
) : ApiException(HttpStatus.FORBIDDEN, code, message, details)

class BadRequestException(
    message: String,
    code: String = "BAD_REQUEST",
    details: Map<String, Any>? = null
) : ApiException(HttpStatus.BAD_REQUEST, code, message, details)
