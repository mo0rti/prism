package {{ package_identifier }}.features.example.repository

import {{ package_identifier }}.features.example.model.Example
import {{ package_identifier }}.features.example.model.ExampleStatus
import org.springframework.data.domain.Page
import org.springframework.data.domain.Pageable
import org.springframework.data.jpa.repository.JpaRepository
import org.springframework.data.jpa.repository.Query
import java.util.UUID

interface ExampleRepository : JpaRepository<Example, UUID> {

    @Query("""
        SELECT e FROM Example e
        WHERE e.status = 'PUBLISHED'
        OR e.createdBy.id = :userId
    """)
    fun findVisibleByUser(userId: UUID, pageable: Pageable): Page<Example>

    fun findByCreatedById(userId: UUID, pageable: Pageable): Page<Example>
}
