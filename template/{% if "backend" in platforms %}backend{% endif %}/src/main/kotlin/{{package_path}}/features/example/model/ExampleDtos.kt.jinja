package {{ package_identifier }}.features.example.model

import jakarta.validation.constraints.NotBlank
import jakarta.validation.constraints.Size
import java.time.Instant
import java.util.UUID

data class CreateExampleRequest(
    @field:NotBlank @field:Size(max = 255) val title: String,
    @field:Size(max = 2000) val description: String? = null
)

data class UpdateExampleRequest(
    @field:Size(min = 1, max = 255) val title: String? = null,
    @field:Size(max = 2000) val description: String? = null,
    val status: ExampleStatus? = null
)

data class ExampleResponse(
    val id: UUID,
    val title: String,
    val description: String?,
    val status: String,
    val createdBy: UUID,
    val createdAt: Instant,
    val updatedAt: Instant
) {
    companion object {
        fun from(example: Example) = ExampleResponse(
            id = example.id,
            title = example.title,
            description = example.description,
            status = example.status.name,
            createdBy = example.createdBy.id,
            createdAt = example.createdAt,
            updatedAt = example.updatedAt
        )
    }
}
