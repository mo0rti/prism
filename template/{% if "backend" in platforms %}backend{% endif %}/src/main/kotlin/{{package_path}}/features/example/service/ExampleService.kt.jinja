package {{ package_identifier }}.features.example.service

import {{ package_identifier }}.auth.model.User
import {{ package_identifier }}.auth.model.UserRole
import {{ package_identifier }}.common.exception.ForbiddenException
import {{ package_identifier }}.common.exception.NotFoundException
import {{ package_identifier }}.common.model.PagedResponse
import {{ package_identifier }}.features.example.model.*
import {{ package_identifier }}.features.example.repository.ExampleRepository
import org.springframework.data.domain.PageRequest
import org.springframework.data.domain.Sort
import org.springframework.stereotype.Service
import org.springframework.transaction.annotation.Transactional
import java.util.UUID

@Service
class ExampleService(
    private val exampleRepository: ExampleRepository
) {

    @Transactional(readOnly = true)
    fun list(user: User, page: Int, size: Int, sort: String): PagedResponse<ExampleResponse> {
        val (sortField, sortDir) = parseSortParam(sort)
        val pageable = PageRequest.of(page, size, Sort.by(sortDir, sortField))
        val results = exampleRepository.findVisibleByUser(user.id, pageable)
        return PagedResponse.from(results) { ExampleResponse.from(it) }
    }

    @Transactional
    fun create(user: User, request: CreateExampleRequest): ExampleResponse {
        val example = exampleRepository.save(
            Example(
                title = request.title,
                description = request.description,
                createdBy = user
            )
        )
        return ExampleResponse.from(example)
    }

    @Transactional(readOnly = true)
    fun getById(id: UUID): ExampleResponse {
        val example = findOrThrow(id)
        return ExampleResponse.from(example)
    }

    @Transactional
    fun update(user: User, id: UUID, request: UpdateExampleRequest): ExampleResponse {
        val example = findOrThrow(id)
        checkOwnerOrAdmin(user, example)

        request.title?.let { example.title = it }
        request.description?.let { example.description = it }
        request.status?.let { example.status = it }

        return ExampleResponse.from(exampleRepository.save(example))
    }

    @Transactional
    fun delete(user: User, id: UUID) {
        val example = findOrThrow(id)
        checkOwnerOrAdmin(user, example)
        exampleRepository.delete(example)
    }

    private fun findOrThrow(id: UUID): Example =
        exampleRepository.findById(id)
            .orElseThrow { NotFoundException("Example not found with id: $id") }

    private fun checkOwnerOrAdmin(user: User, example: Example) {
        if (example.createdBy.id != user.id && user.role != UserRole.ADMIN) {
            throw ForbiddenException("Only the creator or admins can modify this resource")
        }
    }

    private fun parseSortParam(sort: String): Pair<String, Sort.Direction> {
        val parts = sort.split(",")
        val field = parts.getOrElse(0) { "createdAt" }
        val direction = if (parts.getOrElse(1) { "desc" }.equals("asc", ignoreCase = true))
            Sort.Direction.ASC else Sort.Direction.DESC
        return field to direction
    }
}
