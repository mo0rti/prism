package {{ package_identifier }}.features.example

import {{ package_identifier }}.auth.model.*
import {{ package_identifier }}.common.exception.ForbiddenException
import {{ package_identifier }}.common.exception.NotFoundException
import {{ package_identifier }}.features.example.model.*
import {{ package_identifier }}.features.example.repository.ExampleRepository
import {{ package_identifier }}.features.example.service.ExampleService
import org.junit.jupiter.api.Assertions.*
import org.junit.jupiter.api.BeforeEach
import org.junit.jupiter.api.Test
import org.springframework.beans.factory.annotation.Autowired
import org.springframework.boot.test.context.SpringBootTest
import org.springframework.test.context.ActiveProfiles

@SpringBootTest
@ActiveProfiles("test")
class ExampleServiceTest {

    @Autowired
    private lateinit var exampleService: ExampleService

    @Autowired
    private lateinit var exampleRepository: ExampleRepository

    @Autowired
    private lateinit var userRepository: UserRepository

    private lateinit var testUser: User
    private lateinit var otherUser: User
    private lateinit var adminUser: User

    @BeforeEach
    fun setup() {
        exampleRepository.deleteAll()
        userRepository.deleteAll()

        testUser = userRepository.save(User(
            email = "test@example.com",
            displayName = "Test User",
            authProvider = AuthProvider.LOCAL
        ))
        otherUser = userRepository.save(User(
            email = "other@example.com",
            displayName = "Other User",
            authProvider = AuthProvider.LOCAL
        ))
        adminUser = userRepository.save(User(
            email = "admin@example.com",
            displayName = "Admin User",
            authProvider = AuthProvider.LOCAL,
            role = UserRole.ADMIN
        ))
    }

    @Test
    fun `create example returns response`() {
        val response = exampleService.create(testUser, CreateExampleRequest(
            title = "Test Example",
            description = "A test description"
        ))

        assertEquals("Test Example", response.title)
        assertEquals("A test description", response.description)
        assertEquals("DRAFT", response.status)
        assertEquals(testUser.id, response.createdBy)
    }

    @Test
    fun `get example by id returns response`() {
        val created = exampleService.create(testUser, CreateExampleRequest(title = "Test"))
        val response = exampleService.getById(created.id)

        assertEquals(created.id, response.id)
        assertEquals("Test", response.title)
    }

    @Test
    fun `get non-existent example throws not found`() {
        assertThrows(NotFoundException::class.java) {
            exampleService.getById(java.util.UUID.randomUUID())
        }
    }

    @Test
    fun `update own example succeeds`() {
        val created = exampleService.create(testUser, CreateExampleRequest(title = "Original"))
        val updated = exampleService.update(testUser, created.id, UpdateExampleRequest(
            title = "Updated",
            status = ExampleStatus.PUBLISHED
        ))

        assertEquals("Updated", updated.title)
        assertEquals("PUBLISHED", updated.status)
    }

    @Test
    fun `update other user example throws forbidden`() {
        val created = exampleService.create(testUser, CreateExampleRequest(title = "Test"))

        assertThrows(ForbiddenException::class.java) {
            exampleService.update(otherUser, created.id, UpdateExampleRequest(title = "Hacked"))
        }
    }

    @Test
    fun `admin can update any example`() {
        val created = exampleService.create(testUser, CreateExampleRequest(title = "Test"))
        val updated = exampleService.update(adminUser, created.id, UpdateExampleRequest(title = "Admin Updated"))

        assertEquals("Admin Updated", updated.title)
    }

    @Test
    fun `delete own example succeeds`() {
        val created = exampleService.create(testUser, CreateExampleRequest(title = "Test"))
        exampleService.delete(testUser, created.id)

        assertThrows(NotFoundException::class.java) {
            exampleService.getById(created.id)
        }
    }

    @Test
    fun `delete other user example throws forbidden`() {
        val created = exampleService.create(testUser, CreateExampleRequest(title = "Test"))

        assertThrows(ForbiddenException::class.java) {
            exampleService.delete(otherUser, created.id)
        }
    }

    @Test
    fun `list returns paginated results`() {
        repeat(5) { i ->
            exampleService.create(testUser, CreateExampleRequest(title = "Example $i"))
        }

        val response = exampleService.list(testUser, page = 0, size = 3, sort = "createdAt,desc")

        assertEquals(3, response.content.size)
        assertEquals(5, response.totalElements)
        assertEquals(2, response.totalPages)
    }
}
