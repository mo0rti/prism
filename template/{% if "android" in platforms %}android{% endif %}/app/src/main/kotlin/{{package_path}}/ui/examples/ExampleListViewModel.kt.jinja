package {{ package_identifier }}.ui.examples

import androidx.lifecycle.ViewModel
import androidx.lifecycle.viewModelScope
import {{ package_identifier }}.data.repository.AuthRepository
import {{ package_identifier }}.data.repository.ExampleRepository
import {{ package_identifier }}.domain.model.ExampleResponse
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.launch
import javax.inject.Inject

sealed interface ExampleListUiState {
    data object Idle : ExampleListUiState
    data object Loading : ExampleListUiState
    data class Success(
        val examples: List<ExampleResponse>,
        val page: Int,
        val totalPages: Int,
        val isLoadingMore: Boolean = false
    ) : ExampleListUiState
    data class Error(val message: String) : ExampleListUiState
}

@HiltViewModel
class ExampleListViewModel @Inject constructor(
    private val exampleRepository: ExampleRepository,
    private val authRepository: AuthRepository
) : ViewModel() {

    private val _uiState = MutableStateFlow<ExampleListUiState>(ExampleListUiState.Idle)
    val uiState: StateFlow<ExampleListUiState> = _uiState.asStateFlow()

    init {
        loadExamples()
    }

    fun loadExamples() {
        viewModelScope.launch {
            _uiState.value = ExampleListUiState.Loading
            try {
                val response = exampleRepository.list(page = 0)
                _uiState.value = ExampleListUiState.Success(
                    examples = response.content,
                    page = response.page,
                    totalPages = response.totalPages
                )
            } catch (e: Exception) {
                _uiState.value = ExampleListUiState.Error(e.message ?: "Failed to load examples")
            }
        }
    }

    fun loadMore() {
        val current = _uiState.value as? ExampleListUiState.Success ?: return
        if (current.isLoadingMore || current.page + 1 >= current.totalPages) return

        viewModelScope.launch {
            _uiState.value = current.copy(isLoadingMore = true)
            try {
                val response = exampleRepository.list(page = current.page + 1)
                _uiState.value = current.copy(
                    examples = current.examples + response.content,
                    page = response.page,
                    totalPages = response.totalPages,
                    isLoadingMore = false
                )
            } catch (e: Exception) {
                _uiState.value = current.copy(isLoadingMore = false)
            }
        }
    }

    fun deleteExample(id: String) {
        viewModelScope.launch {
            try {
                exampleRepository.delete(id)
                val current = _uiState.value as? ExampleListUiState.Success ?: return@launch
                _uiState.value = current.copy(
                    examples = current.examples.filter { it.id != id }
                )
            } catch (e: Exception) {
                // Silently fail or show snackbar
            }
        }
    }

    fun logout() {
        viewModelScope.launch {
            authRepository.logout()
        }
    }
}
