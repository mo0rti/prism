package {{ package_identifier }}.data.local.db

import androidx.room.Dao
import androidx.room.Insert
import androidx.room.OnConflictStrategy
import androidx.room.Query
import kotlinx.coroutines.flow.Flow

@Dao
interface ExampleDao {

    @Query("SELECT * FROM examples ORDER BY cachedAt DESC")
    fun observeAll(): Flow<List<CachedExample>>

    @Query("SELECT * FROM examples ORDER BY cachedAt DESC")
    suspend fun getAll(): List<CachedExample>

    @Query("SELECT * FROM examples WHERE id = :id")
    suspend fun getById(id: String): CachedExample?

    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insertAll(examples: List<CachedExample>)

    @Query("DELETE FROM examples WHERE id = :id")
    suspend fun deleteById(id: String)

    @Query("DELETE FROM examples")
    suspend fun deleteAll()
}
