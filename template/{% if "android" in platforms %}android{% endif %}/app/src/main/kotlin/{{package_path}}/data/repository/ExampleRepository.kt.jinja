package {{ package_identifier }}.data.repository

import {{ package_identifier }}.data.remote.ApiService
import {{ package_identifier }}.domain.model.*
import javax.inject.Inject
import javax.inject.Singleton

interface ExampleRepository {
    suspend fun list(page: Int = 0, size: Int = 20): ExampleListResponse
    suspend fun getById(id: String): ExampleResponse
    suspend fun create(title: String, description: String?): ExampleResponse
    suspend fun update(id: String, title: String?, description: String?, status: String?): ExampleResponse
    suspend fun delete(id: String)
}

@Singleton
class ExampleRepositoryImpl @Inject constructor(
    private val apiService: ApiService
) : ExampleRepository {

    override suspend fun list(page: Int, size: Int): ExampleListResponse =
        apiService.listExamples(page = page, size = size)

    override suspend fun getById(id: String): ExampleResponse =
        apiService.getExample(id)

    override suspend fun create(title: String, description: String?): ExampleResponse =
        apiService.createExample(CreateExampleRequest(title, description))

    override suspend fun update(id: String, title: String?, description: String?, status: String?): ExampleResponse =
        apiService.updateExample(id, UpdateExampleRequest(title, description, status))

    override suspend fun delete(id: String) =
        apiService.deleteExample(id)
}
