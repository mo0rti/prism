{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "{{ project_slug }}-user-web-app",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-12-11",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "NODE_ENV": "production",
    "NEXT_PUBLIC_API_BASE_URL": "https://api.{{ project_slug }}.com",
    "AUTH_URL": "https://app.{{ project_slug }}.com",
    "AUTH_TRUST_HOST": "true"
  }
}
