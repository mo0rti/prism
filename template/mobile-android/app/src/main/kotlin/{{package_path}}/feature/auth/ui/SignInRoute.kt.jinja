package {{ package_identifier }}.feature.auth.ui

import androidx.compose.runtime.Composable
import androidx.compose.runtime.getValue
import androidx.hilt.lifecycle.viewmodel.compose.hiltViewModel
import androidx.lifecycle.compose.collectAsStateWithLifecycle

private val supportedAuthProviders = listOf("google", "apple", "facebook", "microsoft")

@Composable
fun SignInRoute(
    viewModel: SignInViewModel = hiltViewModel(),
) {
    val uiState by viewModel.uiState.collectAsStateWithLifecycle()
{% if "password" in auth_methods %}
    val email by viewModel.email.collectAsStateWithLifecycle()
    val password by viewModel.password.collectAsStateWithLifecycle()
{% endif %}

    SignInScreen(
        uiState = uiState,
{% if "password" in auth_methods %}
        email = email,
        password = password,
        onEmailChange = viewModel::onEmailChange,
        onPasswordChange = viewModel::onPasswordChange,
        onSignInWithPassword = viewModel::signInWithPassword,
{% endif %}
        providers = supportedAuthProviders,
        onSignInWithOAuth = viewModel::showOAuthSetupRequired,
        onDismissError = viewModel::clearError,
    )
}
