package {{ package_identifier }}.navigation

import androidx.compose.runtime.Composable
import androidx.compose.runtime.getValue
import androidx.hilt.lifecycle.viewmodel.compose.hiltViewModel
import androidx.lifecycle.compose.collectAsStateWithLifecycle
import androidx.lifecycle.ViewModel
import kotlinx.coroutines.flow.StateFlow
import androidx.navigation.compose.NavHost
import androidx.navigation.compose.composable
import androidx.navigation.compose.rememberNavController
import {{ package_identifier }}.feature.auth.AuthConfig
import {{ package_identifier }}.feature.auth.AuthExperienceMode
import {{ package_identifier }}.core.model.AuthState
import {{ package_identifier }}.core.session.SessionManager
import {{ package_identifier }}.designsystem.components.LoadingIndicator
import {{ package_identifier }}.feature.auth.ui.SignInRoute
import {{ package_identifier }}.feature.auth.ui.SocialSignInRoute
import {{ package_identifier }}.feature.example.ui.ExampleListRoute
import dagger.hilt.android.lifecycle.HiltViewModel
import javax.inject.Inject

@HiltViewModel
class NavViewModel @Inject constructor(
    sessionManager: SessionManager,
) : ViewModel() {
    val authState: StateFlow<AuthState> = sessionManager.authState
}

@Composable
fun NavGraph(viewModel: NavViewModel = hiltViewModel()) {
    val authState by viewModel.authState.collectAsStateWithLifecycle()

    AuthGate(authState = authState)
}

@Composable
fun AuthGate(
    authState: AuthState,
    authenticatedContent: @Composable () -> Unit = { AuthenticatedNavGraph() },
    unauthenticatedContent: @Composable () -> Unit = { UnauthenticatedNavGraph() },
    loadingContent: @Composable () -> Unit = { LoadingIndicator() },
) {
    when (authState) {
        is AuthState.Loading -> loadingContent()
        is AuthState.Authenticated -> authenticatedContent()
        is AuthState.Unauthenticated -> unauthenticatedContent()
    }
}

@Composable
private fun AuthenticatedNavGraph() {
    val navController = rememberNavController()

    NavHost(navController = navController, startDestination = Screen.ExampleList) {
        composable<Screen.ExampleList> {
            ExampleListRoute()
        }
    }
}

@Composable
private fun UnauthenticatedNavGraph() {
    val navController = rememberNavController()
    val startDestination = when (AuthConfig.authExperienceMode) {
        AuthExperienceMode.EMAIL_PASSWORD_ONLY -> Screen.SignIn
        AuthExperienceMode.SOCIAL_ONLY, AuthExperienceMode.MIXED -> Screen.SocialSignIn
    }

    NavHost(navController = navController, startDestination = startDestination) {
        composable<Screen.SocialSignIn> {
            SocialSignInRoute(
                onContinueWithEmailPassword = {
                    navController.navigate(Screen.SignIn)
                },
            )
        }
        composable<Screen.SignIn> {
            SignInRoute(
                showBackToSocial = AuthConfig.authExperienceMode == AuthExperienceMode.MIXED,
                onBackToSocial = { navController.popBackStack() },
            )
        }
    }
}
