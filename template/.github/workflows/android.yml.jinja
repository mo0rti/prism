{% if "android" in platforms %}
name: Android CI/CD

on:
  push:
    branches: [main]
    paths:
      - 'android/**'
      - 'shared/**'
    tags:
      - 'v*'
  pull_request:
    branches: [main]
    paths:
      - 'android/**'
      - 'shared/**'

jobs:
  test:
    name: Test
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up JDK 21
        uses: actions/setup-java@v4
        with:
          java-version: '21'
          distribution: 'temurin'

      - name: Cache Gradle
        uses: actions/cache@v4
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
          key: {% raw %}${{ runner.os }}-gradle-android-${{ hashFiles('android/**/*.gradle*', 'android/gradle/wrapper/gradle-wrapper.properties') }}{% endraw %}

      - name: Run tests
        working-directory: android
        run: ./gradlew testDebugUnitTest

      - name: Lint
        working-directory: android
        run: ./gradlew lintDebug

  build:
    name: Build Debug APK
    needs: test
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up JDK 21
        uses: actions/setup-java@v4
        with:
          java-version: '21'
          distribution: 'temurin'

      - name: Build debug APK
        working-directory: android
        run: ./gradlew assembleDebug

      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: debug-apk
          path: android/app/build/outputs/apk/debug/app-debug.apk

  release:
    name: Release to Play Store
    needs: test
    if: startsWith(github.ref, 'refs/tags/v')
    runs-on: ubuntu-latest
    environment: production
    steps:
      - uses: actions/checkout@v4

      - name: Set up JDK 21
        uses: actions/setup-java@v4
        with:
          java-version: '21'
          distribution: 'temurin'

      - name: Set up Ruby
        uses: ruby/setup-ruby@v1
        with:
          ruby-version: '3.2'
          bundler-cache: true
          working-directory: android

      - name: Decode keystore
        working-directory: android
        run: echo {% raw %}${{ secrets.ANDROID_KEYSTORE_BASE64 }}{% endraw %} | base64 -d > app/keystore.jks

      - name: Build release bundle
        working-directory: android
        run: |
          ./gradlew bundleRelease \
            -Pandroid.injected.signing.store.file=$PWD/app/keystore.jks \
            -Pandroid.injected.signing.store.password={% raw %}${{ secrets.ANDROID_KEYSTORE_PASSWORD }}{% endraw %} \
            -Pandroid.injected.signing.key.alias={% raw %}${{ secrets.ANDROID_KEY_ALIAS }}{% endraw %} \
            -Pandroid.injected.signing.key.password={% raw %}${{ secrets.ANDROID_KEY_PASSWORD }}{% endraw %}

      - name: Deploy to Play Store
        working-directory: android
        env:
          SUPPLY_JSON_KEY_DATA: {% raw %}${{ secrets.GOOGLE_PLAY_SERVICE_ACCOUNT_JSON }}{% endraw %}
        run: bundle exec fastlane release
{% endif %}
