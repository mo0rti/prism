{% if "user-web-app" in platforms %}
name: User Web App CI/CD

on:
  push:
    branches: [main]
    paths:
      - "user-web-app/**"
      - "shared/**"
  pull_request:
    branches: [main]
    paths:
      - "user-web-app/**"
      - "shared/**"

jobs:
  lint-typecheck-build:
    name: Lint, Typecheck, Build
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "lts/*"

      - name: Install dependencies
        working-directory: user-web-app
        run: npm install

      - name: Lint
        working-directory: user-web-app
        run: npm run lint

      - name: Typecheck
        working-directory: user-web-app
        run: npm run typecheck

      - name: Build
        working-directory: user-web-app
        run: npm run build

  deploy:
    name: Deploy to Cloudflare
    needs: lint-typecheck-build
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'
    runs-on: ubuntu-latest
    environment: production
    steps:
      - uses: actions/checkout@v4

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "lts/*"

      - name: Install dependencies
        working-directory: user-web-app
        run: npm install

      - name: Build Cloudflare bundle
        working-directory: user-web-app
        run: npm run build:cloudflare

      - name: Deploy worker
        working-directory: user-web-app
        run: npx wrangler deploy
        env:
          CLOUDFLARE_API_TOKEN: {% raw %}${{ secrets.CLOUDFLARE_API_TOKEN }}{% endraw %}
          CLOUDFLARE_ACCOUNT_ID: {% raw %}${{ secrets.CLOUDFLARE_ACCOUNT_ID }}{% endraw %}
{% endif %}
