{% if "backend" in platforms %}
name: Backend CI/CD

on:
  push:
    branches: [main]
    paths:
      - 'backend/**'
      - 'shared/api-contracts/**'
  pull_request:
    branches: [main]
    paths:
      - 'backend/**'
      - 'shared/api-contracts/**'
  workflow_dispatch:

jobs:
  test:
    name: Test
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up JDK 21
        uses: actions/setup-java@v4
        with:
          java-version: '21'
          distribution: 'temurin'

      - name: Cache Gradle
        uses: actions/cache@v4
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
          key: {% raw %}${{ runner.os }}-gradle-${{ hashFiles('backend/**/*.gradle*', 'backend/gradle/wrapper/gradle-wrapper.properties') }}{% endraw %}

      - name: Run tests
        working-directory: backend
        run: ./gradlew test

      - name: Upload test results
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: test-results
          path: backend/build/reports/tests/

{% if cloud_provider == "azure" %}
  build-and-push:
    name: Build & Push Image
    needs: test
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Login to Azure Container Registry
        uses: azure/docker-login@v2
        with:
          login-server: {% raw %}${{ secrets.AZURE_CONTAINER_REGISTRY }}{% endraw %}
          username: {% raw %}${{ secrets.ACR_USERNAME }}{% endraw %}
          password: {% raw %}${{ secrets.ACR_PASSWORD }}{% endraw %}

      - name: Build and push Docker image
        working-directory: backend
        run: |
          IMAGE={% raw %}${{ secrets.AZURE_CONTAINER_REGISTRY }}{% endraw %}/{{ project_slug }}-backend
          docker build -t $IMAGE:{% raw %}${{ github.sha }}{% endraw %} -t $IMAGE:latest .
          docker push $IMAGE:{% raw %}${{ github.sha }}{% endraw %}
          docker push $IMAGE:latest

  deploy:
    name: Deploy to Azure
    needs: build-and-push
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'
    runs-on: ubuntu-latest
    environment: production
    steps:
      - uses: actions/checkout@v4

      - name: Azure Login
        uses: azure/login@v2
        with:
          creds: {% raw %}${{ secrets.AZURE_CREDENTIALS }}{% endraw %}

      - name: Deploy to Container Apps
        run: |
          IMAGE={% raw %}${{ secrets.AZURE_CONTAINER_REGISTRY }}{% endraw %}/{{ project_slug }}-backend:{% raw %}${{ github.sha }}{% endraw %}
          REVISION="sha-$(echo {% raw %}${{ github.sha }}{% endraw %} | head -c 8)"
          az containerapp update \
            --resource-group {% raw %}${{ secrets.AZURE_RESOURCE_GROUP }}{% endraw %} \
            --name {% raw %}${{ secrets.AZURE_CONTAINER_APP_NAME }}{% endraw %} \
            --image "$IMAGE" \
            --revision-suffix "$REVISION"
{% endif %}
{% endif %}
