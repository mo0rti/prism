# =============================================================================
# {{ project_name }} — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

{% if "backend" in platforms %}
# =============================================================================
# Backend
# =============================================================================
{% if database == "postgres" %}
DATABASE_URL=jdbc:postgresql://localhost:5432/{{ project_slug | replace('-', '_') }}
DATABASE_USERNAME={{ project_slug | replace('-', '_') }}
DATABASE_PASSWORD=localdev
{% elif database == "mysql" %}
DATABASE_URL=jdbc:mysql://localhost:3306/{{ project_slug | replace('-', '_') }}
DATABASE_USERNAME={{ project_slug | replace('-', '_') }}
DATABASE_PASSWORD=localdev
{% endif %}

# JWT
JWT_SECRET=your-jwt-secret-change-this-in-production
JWT_EXPIRATION_MS=86400000

{% if "google" in auth_methods %}
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
{% endif %}
{% if "apple" in auth_methods %}
# Apple Sign-In
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=path/to/AuthKey.p8
{% endif %}
{% if "facebook" in auth_methods %}
# Facebook Login
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
{% endif %}
{% if "microsoft" in auth_methods %}
# Microsoft Account
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=your-microsoft-tenant-id
{% endif %}
{% endif %}

{% if cloud_provider == "azure" %}
# =============================================================================
# Azure
# =============================================================================
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP={{ project_slug }}-rg
AZURE_CONTAINER_REGISTRY={{ project_slug | replace('-', '') }}acr.azurecr.io
{% endif %}

{% if "web" in platforms or "admin" in platforms %}
# =============================================================================
# Web / Admin
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
{% if web_hosting == "cloudflare" %}
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
{% endif %}
{% endif %}
